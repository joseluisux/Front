  <script>
    // Open modal — reset to initial state (step 1 open)
    document.querySelector('.btn-connect').addEventListener('click', function() {
      // Reset all accordions
      document.querySelectorAll('.accordion-item').forEach(item => {
        item.classList.remove('active', 'completed');
      });
      // Open step 1
      document.querySelector('[data-accordion="1"]').classList.add('active');
      document.getElementById('connectModal').classList.add('active');
    });

    // Close modal
    function closeModal() {
      document.getElementById('connectModal').classList.remove('active');
    }

    document.getElementById('modalClose').addEventListener('click', closeModal);

    document.getElementById('connectModal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    // Accordion toggle (click header)
    function toggleAccordion(num) {
      const items = document.querySelectorAll('.accordion-item');
      items.forEach(item => {
        const id = parseInt(item.getAttribute('data-accordion'));
        if (id === num) {
          // Only toggle if not completed, or allow re-open completed
          item.classList.toggle('active');
        } else {
          item.classList.remove('active');
        }
      });
    }

    // Save section — mark completed, green check, open next
    function saveSection(num) {
      const current = document.querySelector('[data-accordion="' + num + '"]');
      if (!current) return;

      // 1. Close and mark as completed
      current.classList.remove('active');
      current.classList.add('completed');

      // 2. After a short delay, open the next section
      const nextNum = num + 1;
      const next = document.querySelector('[data-accordion="' + nextNum + '"]');

      if (next) {
        setTimeout(function() {
          next.classList.add('active');
          // Scroll modal to show next section
          next.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 350);
      } else {
        // All steps completed — show success
        setTimeout(function() {
          showCompletionMessage();
        }, 400);
      }
    }

    // Show completion message
    function showCompletionMessage() {
      // Check if all are completed
      const items = document.querySelectorAll('.accordion-item');
      let allCompleted = true;
      items.forEach(item => {
        if (!item.classList.contains('completed')) allCompleted = false;
      });

      if (allCompleted) {
        // Create success overlay
        const successDiv = document.createElement('div');
        successDiv.id = 'successMessage';
        successDiv.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:200;display:flex;align-items:center;justify-content:center;';
        successDiv.innerHTML = '<div style="background:#fff;border-radius:16px;padding:40px;text-align:center;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.15);">' +
          '<div style="width:56px;height:56px;border-radius:50%;background:#dcfce7;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">' +
          '<span class="material-icons-outlined" style="font-size:32px;color:#16a34a;">check_circle</span></div>' +
          '<h3 style="font-size:18px;font-weight:700;color:#111827;margin-bottom:8px;">¡Configuración completada!</h3>' +
          '<p style="font-size:14px;color:#6b7280;margin-bottom:24px;">Tu tienda está lista para Google Merchant Center.</p>' +
          '<button onclick="closeSuccess()" style="padding:10px 28px;border:none;border-radius:10px;background:#dc2626;color:#fff;font-size:14px;font-weight:600;cursor:pointer;">Aceptar</button>' +
          '</div>';
        document.body.appendChild(successDiv);
      }
    }

    function closeSuccess() {
      const msg = document.getElementById('successMessage');
      if (msg) msg.remove();
      closeModal();
    }

    // Radio select
    function selectRadio(el) {
      const parent = el.closest('.radio-options');
      parent.querySelectorAll('.radio-option').forEach(opt => opt.classList.remove('selected'));
      el.classList.add('selected');
    }

    // Character count
    function updateCharCount() {
      const input = document.getElementById('businessNameInput');
      const count = document.getElementById('charCount');
      if (input && count) {
        count.textContent = input.value.length + '/40';
      }
    }
  </script>

</body>
</html>
